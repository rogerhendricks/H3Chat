## Example environment variables for H3Chat
# Copy this file to .env and fill values for local development.

# Database (Postgres)
DB_HOST=IP of postgres container
DB_PORT=Port of postgres container
DB_NAME=database name
DB_USER=postgres
DB_PASS=changeme

# Embedding model identifier (used by SentenceTransformer)
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Ollama (local LLM HTTP API)
OLLAMA_URL=http://ollama:11434/api/generate
LLM_MODEL_NAME=qwen3.5:9b

# Set timeout for Ollama
OLLAMA_TIMEOUT_SECONDS=600

# Optional runtime flags
LOG_LEVEL=INFO
ENV=development
